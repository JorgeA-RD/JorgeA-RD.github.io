---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import AuthorLink from '../components/AuthorLink.astro';
import bibFileRaw from '../data/publications.bib?raw';

interface Author {
    first: string;
    last: string;
}

interface BibEntry {
    type: string;
    key: string;
    fields: Record<string, string>;
    authors: Author[];
}

interface PublicationSection {
    title: string;
    prefix: string;
    entries: BibEntry[];
}

function parseBibTeX(input: string): BibEntry[] {
    const entries: BibEntry[] = [];
    const rawEntries = input.split(/@(\w+)\s*\{/g).slice(1);

    for (let i = 0; i < rawEntries.length; i += 2) {
        const type = rawEntries[i].trim().toLowerCase();
        const body = rawEntries[i+1];
        if (!body) continue;

        const keyMatch = body.match(/^\s*([^,]+),/);
        const key = keyMatch ? keyMatch[1].trim() : 'unknown';
        
        const fields: Record<string, string> = { title: "Untitled", year: "0000" };
        
        const fieldRegex = /(\w+)\s*=\s*(?:\{((?:[^{}]|{[^{}]*})*)\}|"((?:[^"]|\\")*)"|(\d+))/g;
        
        let match;
        while ((match = fieldRegex.exec(body)) !== null) {
            const fieldKey = match[1].toLowerCase();
            const val = match[2] || match[3] || match[4] || "";
            fields[fieldKey] = val.replace(/\s+/g, ' ').trim();
        }

        let authors: Author[] = [];
        if (fields.author) {
            authors = fields.author.split(/\s+and\s+/i).map(str => {
                const parts = str.split(',');
                if (parts.length > 1) {
                    return { first: parts[1].trim(), last: parts[0].trim() };
                } else {
                    const names = str.trim().split(' ');
                    const last = names.pop() || "";
                    const first = names.join(' ');
                    return { first, last };
                }
            });
        }

        entries.push({ type, key, fields, authors });
    }
    return entries;
}

const clean = (value?: string) => (value || '').replace(/[{}]/g, '');

const formatAuthor = (auth: Author) => {
    return auth.first ? `${auth.first} ${auth.last}` : auth.last;
};

const yearValue = (entry: BibEntry) => parseInt(entry.fields.year) || 0;
const sortNewestFirst = (entries: BibEntry[]) => entries.sort((a, b) => yearValue(b) - yearValue(a));

const allPublications = parseBibTeX(bibFileRaw);

const sections: PublicationSection[] = [
    {
        title: 'Journal Articles',
        prefix: 'J',
        entries: sortNewestFirst(allPublications.filter(entry => entry.type === 'article')),
    },
    {
        title: 'Conference Papers',
        prefix: 'C',
        entries: sortNewestFirst(allPublications.filter(entry => entry.type === 'inproceedings' || entry.type === 'conference')),
    },
    {
        title: 'Preprints',
        prefix: 'P',
        entries: sortNewestFirst(allPublications.filter(entry => entry.type === 'unpublished' || entry.type === 'preprint')),
    },
    {
        title: 'Theses',
        prefix: 'T',
        entries: sortNewestFirst(allPublications.filter(entry => entry.type === 'phdthesis' || entry.type === 'mastersthesis')),
    },
].filter(section => section.entries.length > 0);

const getVenue = (entry: BibEntry) => clean(
    entry.fields.journal ||
    entry.fields.booktitle ||
    entry.fields.publisher ||
    entry.fields.school ||
    entry.fields.note ||
    'Preprint'
);

const getPrimaryLink = (entry: BibEntry) => {
    if (entry.fields.doi) return `https://doi.org/${entry.fields.doi}`;
    if (entry.fields.url) return entry.fields.url;
    if (entry.fields.pdf) return entry.fields.pdf;
    return '';
};

const makeBibTeX = (entry: BibEntry) => {
    const lines = [
        `@${entry.type}{${entry.key},`,
        `  title={${entry.fields.title}},`,
        `  author={${entry.fields.author || ''}},`,
    ];

    if (entry.fields.journal) lines.push(`  journal={${entry.fields.journal}},`);
    if (entry.fields.booktitle) lines.push(`  booktitle={${entry.fields.booktitle}},`);
    if (entry.fields.school) lines.push(`  school={${entry.fields.school}},`);
    if (entry.fields.note) lines.push(`  note={${entry.fields.note}},`);
    if (entry.fields.doi) lines.push(`  doi={${entry.fields.doi}},`);
    lines.push(`  year={${entry.fields.year}}`);
    lines.push('}');

    return lines.join('\n');
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Publications | ${SITE_TITLE}`} description="Academic Publications" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Publications</h1>
			<p>Selected academic publications, organized by type and listed with the most recent work first within each section.</p>
			
            {sections.length > 0 ? sections.map((section) => (
                <section class="publication-section">
                    <h2>{section.title}</h2>
                    <ol class="publication-list compact-publications">
                        {section.entries.map((entry, index) => {
                            const primaryLink = getPrimaryLink(entry);
                            const bibtex = makeBibTeX(entry);
                            return (
                                <li class="publication-item compact-publication">
                                    <span class="pub-number">[{section.prefix}{index + 1}]</span>
                                    <div class="pub-content">
                                        <span class="pub-title">{clean(entry.fields.title)}</span>
                                        <div class="pub-authors">
                                            {entry.authors && entry.authors.map((auth, i) => (
                                                <>
                                                    <AuthorLink nameOrSlug={formatAuthor(auth)} />
                                                    {i < entry.authors.length - 1 ? ', ' : ''}
                                                </>
                                            ))}
                                        </div>
                                        <div class="pub-venue">
                                            {getVenue(entry)}{entry.fields.year && <span>, {entry.fields.year}</span>}
                                        </div>
                                        <div class="pub-links">
                                            {primaryLink && <a href={primaryLink} target="_blank" rel="noopener noreferrer">Article</a>}
                                            {entry.fields.doi && <a href={`https://doi.org/${entry.fields.doi}`} target="_blank" rel="noopener noreferrer">DOI</a>}
                                            {entry.fields.pdf && <a href={entry.fields.pdf} target="_blank" rel="noopener noreferrer">PDF</a>}
                                            <details name="bibtex" class="bibtex-details">
                                                <summary>BibTeX</summary>
                                                <div class="bibtex-panel">
                                                    <div class="bibtex-actions">
                                                        <button class="copy-bibtex-btn" data-bibtex={bibtex}>
                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                                            <span class="copy-text">Copy</span>
                                                        </button>
                                                    </div>
                                                    <pre>{bibtex}</pre>
                                                </div>
                                            </details>
                                        </div>
                                    </div>
                                </li>
                            );
                        })}
                    </ol>
                </section>
            )) : (
                <p>No publications found.</p>
            )}
		</main>
		<Footer />

		<script>
            // Ensure only one BibTeX panel is open at a time (fallback for browsers without 'name' attr support)
			const detailsElements = document.querySelectorAll('details[name="bibtex"]');
			detailsElements.forEach(details => {
				details.addEventListener('toggle', () => {
					if (details.hasAttribute('open')) {
						detailsElements.forEach(other => {
							if (other !== details && other.hasAttribute('open')) {
								other.removeAttribute('open');
							}
						});
					}
				});
			});

            // Copy to clipboard functionality
			const copyBtns = document.querySelectorAll('.copy-bibtex-btn');
			copyBtns.forEach(btn => {
				btn.addEventListener('click', async (e) => {
					e.preventDefault();
					const bibtex = btn.getAttribute('data-bibtex');
					const textSpan = btn.querySelector('.copy-text');
					if (bibtex && textSpan) {
						try {
							await navigator.clipboard.writeText(bibtex);
							textSpan.textContent = 'Copied!';
							setTimeout(() => {
								textSpan.textContent = 'Copy';
							}, 2000);
						} catch (err) {
							console.error('Failed to copy', err);
						}
					}
				});
			});
		</script>
	</body>
</html>
