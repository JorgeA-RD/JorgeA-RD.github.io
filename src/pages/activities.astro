---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Activities | ${SITE_TITLE}`} description="Academic activities, service, memberships, reviewing, and talks." />
		<style>
			.activities-page {
				max-width: 850px;
				margin: 0 auto;
			}

			.activities-intro {
				margin-bottom: 2.5rem;
			}

			.activities-intro p {
				color: var(--color-text-muted);
				font-size: 1rem;
				line-height: 1.7;
			}

			.activity-section {
				margin-top: 2.5rem;
				padding-top: 1.75rem;
				border-top: 1px solid var(--color-border);
			}

			.activities-intro + .activity-section {
				border-top: none;
				padding-top: 0;
			}

			.activity-section h2 {
				font-size: 1.35rem;
				margin: 0 0 0.9rem;
			}

			.section-note {
				margin: -0.4rem 0 1rem;
				color: var(--color-text-muted);
				font-size: 0.92rem;
				line-height: 1.42;
			}

			.activity-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 1rem;
			}

			.activity-item {
				padding-left: 1rem;
				border-left: 3px solid var(--color-accent-light);
			}

			.activity-item h3 {
				font-size: 0.98rem;
				line-height: 1.42;
				margin: 0 0 0.25rem;
				color: var(--color-text-main);
			}

			.activity-item p {
				margin: 0;
				color: var(--color-text-muted);
				font-size: 0.92rem;
				line-height: 1.42;
			}

			.activity-meta {
				color: var(--color-accent);
				font-size: 0.82rem;
				font-weight: 700;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="activities-page">
			<section class="activities-intro">
				<h1>Activities</h1>
				<p>Contributions to the academic community beyond publications and research projects.</p>
			</section>

			<section class="activity-section">
				<h2>Professional Societies</h2>
				<ul class="activity-list">
					<li class="activity-item">
						<h3>LatinX in AI (LXAI)</h3>
						<p><span class="activity-meta">Member</span> · 2023–Present</p>
					</li>
					<li class="activity-item">
						<h3>Mexican Academy of Computation</h3>
						<p><span class="activity-meta">Adherent member</span> · 2025–Present</p>
					</li>
				</ul>
			</section>

			<section class="activity-section">
				<h2>Teaching</h2>
				<ul class="activity-list">
					<li class="activity-item">
						<h3>Algorithms and Data Structures</h3>
						<p><span class="activity-meta">UNAM ENES Juriquilla</span> · August 2026</p>
						<p>For third-year students in the B.Sc. program in Mathematics for Development.</p>
					</li>
				</ul>
			</section>

			<section class="activity-section">
				<h2>Conference Participation</h2>
				<p class="section-note">Member of Organizing Committee</p>
				<ul class="activity-list">
					<li class="activity-item">
						<h3>17th International Conference on Electrical Engineering, Computing Science and Automatic Control (CCE 2020)</h3>
						<p><span class="activity-meta">Volunteer</span> · Mexico City, Mexico · November 2020</p>
					</li>
					<li class="activity-item">
						<h3>18th International Conference on Electrical Engineering, Computing Science and Automatic Control (CCE 2021)</h3>
						<p><span class="activity-meta">Volunteer</span> · Mexico City, Mexico · November 2021</p>
					</li>
					<li class="activity-item">
						<h3>18th IEEE International Conference on Automation Science and Engineering (IEEE CASE 2022)</h3>
						<p><span class="activity-meta">Volunteer</span> · Mexico City, Mexico · August 2022</p>
					</li>
					<li class="activity-item">
						<h3>19th International Conference on Electrical Engineering, Computing Science and Automatic Control (CCE 2022)</h3>
						<p><span class="activity-meta">Volunteer</span> · Mexico City, Mexico · November 2022</p>
					</li>
				</ul>
			</section>

			<section class="activity-section">
				<h2>Reviewer Service</h2>
				<ul class="activity-list">
					<li class="activity-item">
						<h3>IEEE Transactions on Neural Networks and Learning Systems</h3>
						<p>11 reviews</p>
					</li>
					<li class="activity-item">
						<h3>Congreso Mexicano de Inteligencia Artificial</h3>
						<p>3 reviews</p>
					</li>
					<li class="activity-item">
						<h3>Computer Applications in Engineering Education</h3>
						<p>2 reviews</p>
					</li>
					<li class="activity-item">
						<h3>LatinX in AI at Neural Information Processing Systems Conference</h3>
						<p>2 reviews</p>
					</li>
					<li class="activity-item">
						<h3>Frontiers in Neurorobotics</h3>
						<p>1 review</p>
					</li>
					<li class="activity-item">
						<h3>Engineering Applications of Artificial Intelligence</h3>
						<p>1 review</p>
					</li>
				</ul>
			</section>

			<section class="activity-section">
				<h2>Talks</h2>
				<ul class="activity-list">
					<li class="activity-item">
						<h3>Beyond Code: Exploring AI in Robotics and Computer Vision</h3>
						<p><span class="activity-meta">Spanish</span> · 3er Congreso Internacional Computación e Ingeniería de Software (CinSoft 2023), Tlahuelilpan, Hidalgo, Mexico · October 2023</p>
					</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
