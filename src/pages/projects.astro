---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import projectsData from '../data/projects.json';

const projects = projectsData.sort((a, b) => b.year - a.year);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="Research projects and associated academic outputs" />
		<style>
			.projects-section {
				max-width: var(--max-width);
				margin: 0 auto;
			}
			.projects-hero {
				text-align: left;
				margin-bottom: 3rem;
				padding: 2rem 0 1rem;
			}
			.projects-hero h1 {
				font-family: var(--font-serif);
				font-size: 3.2rem;
				margin: 0 0 1rem;
				color: var(--color-text-main);
				letter-spacing: -0.02em;
				line-height: 1.2;
			}
			.projects-hero p {
				font-size: 1.08rem;
				color: var(--color-text-muted);
				max-width: 760px;
				line-height: 1.7;
				margin: 0;
			}
			.projects-list {
				list-style: none;
				padding: 0;
				margin: 0 0 4rem;
			}
			.project-item {
				padding: 2rem 0;
				border-top: 1px solid var(--color-border);
			}
			.project-item:last-child {
				border-bottom: 1px solid var(--color-border);
			}
			.project-kicker {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				align-items: center;
				margin-bottom: 0.65rem;
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			.project-period {
				color: var(--color-accent);
			}
			.project-status {
				color: var(--color-text-muted);
			}
			.project-item h2 {
				font-family: var(--font-serif);
				font-size: 1.7rem;
				line-height: 1.3;
				margin: 0 0 0.75rem;
				color: var(--color-text-main);
			}
			.project-description {
				color: var(--color-text-muted);
				font-size: 1rem;
				line-height: 1.7;
				max-width: 860px;
				margin: 0 0 1.25rem;
			}
			.outputs-title {
				font-size: 0.86rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				color: var(--color-text-main);
				margin: 0 0 0.65rem;
			}
			.outputs-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.55rem;
			}
			.output-item {
				color: var(--color-text-muted);
				line-height: 1.55;
			}
			.output-type {
				font-weight: 700;
				color: var(--color-text-main);
			}
			.output-item a {
				color: var(--color-text-main);
				font-weight: 500;
				text-decoration-thickness: 1px;
				text-underline-offset: 0.18em;
			}
			@media (max-width: 768px) {
				.projects-hero h1 { font-size: 2.5rem; }
				.project-item h2 { font-size: 1.45rem; }
				.project-item { padding: 1.6rem 0; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="projects-section">
			<div class="projects-hero">
				<h1>Research Projects</h1>
				<p>Research lines connecting robot behavior learning, reinforcement learning from expert demonstrations, imitation learning, and neural network-based robot control.</p>
			</div>

			<ul class="projects-list">
				{projects.length > 0 ? projects.map((project) => (
					<li class="project-item" id={project.id}>
						<div class="project-kicker">
							<span class="project-period">{project.period}</span>
							<span aria-hidden="true">·</span>
							<span class="project-status">{project.status}</span>
						</div>
						<h2>{project.title}</h2>
						<p class="project-description">{project.description}</p>
						{project.outputs && project.outputs.length > 0 && (
							<div class="project-outputs">
								<h3 class="outputs-title">Associated outputs</h3>
								<ul class="outputs-list">
									{project.outputs.map((output) => (
										<li class="output-item">
											<span class="output-type">{output.type}:</span>{' '}
											{output.href ? (
												<a href={output.href} target="_blank" rel="noopener noreferrer">{output.label}</a>
											) : (
												<span>{output.label}</span>
											)}
										</li>
									))}
								</ul>
							</div>
						)}
					</li>
				)) : (
					<li>No projects found in <code>src/data/projects.json</code>.</li>
				)}
			</ul>
		</main>
		<Footer />
	</body>
</html>
