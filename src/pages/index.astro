---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SOCIAL_LINKS } from '../consts';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import bibFileRaw from '../data/publications.bib?raw';
import { url } from '../utils/paths';

const postEntries = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

const posts = await Promise.all(postEntries.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
}));

interface Author {
	first: string;
	last: string;
}

interface BibEntry {
	type: string;
	key: string;
	fields: Record<string, string>;
	authors: Author[];
}

function parseBibTeX(input: string): BibEntry[] {
    const entries: BibEntry[] = [];
    const rawEntries = input.split(/@(\w+)\s*\{/g).slice(1);

    for (let i = 0; i < rawEntries.length; i += 2) {
        const type = rawEntries[i].trim();
        const body = rawEntries[i+1];
        if (!body) continue;

        const keyMatch = body.match(/^\s*([^,]+),/);
        const key = keyMatch ? keyMatch[1].trim() : 'unknown';
        const fields: Record<string, string> = { title: "Untitled", year: "0000" };
        const fieldRegex = /(\w+)\s*=\s*(?:\{((?:[^{}]|{[^{}]*})*)\}|"((?:[^"]|\\")*)"|(\d+))/g;
        let match;
        while ((match = fieldRegex.exec(body)) !== null) {
            const fieldKey = match[1].toLowerCase();
            const val = match[2] || match[3] || match[4] || "";
            fields[fieldKey] = val.replace(/\s+/g, ' ').trim();
        }
        let authors: Author[] = [];
        if (fields.author) {
            authors = fields.author.split(/\s+and\s+/i).map(str => {
                const parts = str.split(',');
                if (parts.length > 1) {
                    return { first: parts[1].trim(), last: parts[0].trim() };
                }
                const names = str.trim().split(' ');
                const last = names.pop() || "";
                const first = names.join(' ');
                return { first, last };
            });
        }
        entries.push({ type, key, fields, authors });
    }
    return entries;
}

const publications = parseBibTeX(bibFileRaw).filter((entry) => entry.type === 'article').sort((a, b) => {
    return (parseInt(b.fields.year) || 0) - (parseInt(a.fields.year) || 0);
}).slice(0, 2);

const formatAuthor = (auth: Author) => auth.first ? `${auth.first} ${auth.last}` : auth.last;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: flex;
				align-items: flex-start;
				gap: 4rem;
				padding: 4rem 0 1rem;
				margin-bottom: 0;
			}
			.hero-content { flex: 3; }
			.hero-image { flex: 2; align-items: center; display: flex; flex-direction: column; position: relative; text-align: center; }
			.hero-image img {
				width: 280px;
				height: 280px;
				object-fit: cover;
				border-radius: 50%;
				border: 6px solid var(--color-bg);
				box-shadow: 0 0 0 1px var(--color-border), var(--shadow-lg);
			}
            .tagline { color: var(--color-text-muted); margin-bottom: 1.5rem; font-family: var(--font-sans); text-transform: uppercase; letter-spacing: 0.05em; font-size: 1rem; }
            .pub-mini-item { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px dashed var(--color-border); }
            .pub-mini-item:last-child { border-bottom: none; margin-bottom: 0; }
            .pub-title { font-weight: 700; color: var(--color-text-main); display: block; margin-bottom: 0.25rem; font-family: var(--font-serif); font-size: 1.1rem; }
            .pub-meta { font-size: 0.9rem; color: var(--color-text-muted); }
			.hero-buttons { display: flex; gap: 1rem; flex-wrap: wrap; }
            .outreach-note {
                margin-top: 1.25rem;
                padding: 1.25rem 1.5rem;
                border: 1px solid var(--color-border);
                border-radius: 16px;
                background: var(--color-bg-offset);
                max-width: 560px;
            }
            .outreach-note p {
                color: var(--color-text-muted);
                font-size: 0.98rem;
                line-height: 1.65;
                margin: 0 0 0.85rem;
            }
            .outreach-note .btn {
                font-size: 0.9rem;
                padding: 0.55rem 0.95rem;
            }
            .social-inline { display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 0 0 0.25rem; }
            .social-inline a { font-size: 0.95rem; font-weight: 600; }
            .research-interests {
                display: flex;
                flex-wrap: wrap;
                gap: 0.6rem;
                list-style: none;
                padding: 0;
                margin: 0 0 1.75rem;
            }
            .research-interests li {
                border: 1px solid var(--color-border);
                border-radius: 999px;
                color: var(--color-text-muted);
                font-size: 0.9rem;
                padding: 0.35rem 0.75rem;
            }
            .academic-background {
                margin: 1.5rem 0 0;
                max-width: 360px;
                text-align: left;
            }
            .academic-background h2,
            .hero-subtitle {
                font-family: var(--font-sans);
                font-size: 0.9rem;
                letter-spacing: 0.05em;
                margin: 0 0 0.85rem;
                text-transform: uppercase;
            }
            .background-group {
                margin: 0 0 1rem;
            }
            .background-group:last-child {
                margin-bottom: 0;
            }
            .background-group h3 {
                color: var(--color-text-main);
                font-family: var(--font-sans);
                font-size: 0.95rem;
                margin: 0 0 0.45rem;
            }
            .background-list {
                color: var(--color-text-muted);
                font-size: 0.88rem;
                line-height: 1.5;
                list-style: none;
                margin: 0;
                padding: 0;
            }
            .background-list li {
                margin-bottom: 0.35rem;
                padding-left: 0.85rem;
                position: relative;
            }
            .background-list li::before {
                content: '–';
                left: 0;
                position: absolute;
            }
            .background-list li:last-child {
                margin-bottom: 0;
            }
            .profile-panel {
                border: 1px solid var(--color-border);
                border-radius: 18px;
                padding: 2rem;
                background: var(--color-bg-offset);
                margin: 1rem 0 3rem;
            }
            .profile-panel h2 { margin-top: 0; }
            .profile-grid {
                display: grid;
                grid-template-columns: minmax(0, 2fr) minmax(220px, 1fr);
                gap: 2rem;
                align-items: start;
            }
            .identifier-list {
                list-style: none;
                padding: 0;
                margin: 0;
            }
            .identifier-list li { margin-bottom: 0.65rem; }
            .identifier-list a { font-weight: 600; }
            .news-list {
                list-style: none;
                padding: 0;
                margin: 0;
            }
            .news-item {
                margin-bottom: 1.5rem;
                padding-bottom: 1.5rem;
                border-bottom: 1px dashed var(--color-border);
            }
            .news-item:last-child { border-bottom: none; }
            .news-title {
                display: block;
                font-family: var(--font-serif);
                font-size: 1.1rem;
                font-weight: 600;
                color: var(--color-text-main);
                margin-bottom: 0.25rem;
            }
            .news-date {
                color: var(--color-text-muted);
                text-transform: uppercase;
                font-size: 0.8rem;
            }
            .news-body {
                color: var(--color-text-muted);
                line-height: 1.65;
                margin-top: 0.75rem;
                font-size: 0.98rem;
            }
            .news-body :global(p) {
                margin: 0 0 0.75rem;
            }
            .news-body :global(p:last-child) {
                margin-bottom: 0;
            }
			@media (max-width: 768px) {
				.hero { flex-direction: column-reverse; text-align: center; padding: 2rem 0; gap: 2rem; }
                .hero-image img { width: 200px; height: 200px; }
                .hero-buttons, .social-inline, .research-interests { justify-content: center; }
                .outreach-note { margin-left: auto; margin-right: auto; }
                .profile-grid { grid-template-columns: 1fr; }
                .profile-panel { padding: 1.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<h1 style="margin-bottom: 0.5rem; font-size: 3rem;">Jorge Armando Ramirez Diaz</h1>
					<p style="font-size: 1.1rem; line-height: 1.7; margin-bottom: 1.5rem;">
						I am a scientist specializing in artificial intelligence and robotics, with a strong focus on developing machine learning algorithms and deploying them in robotic systems.
					</p>
                    <h2 class="hero-subtitle">Research Interests</h2>
                    <ul class="research-interests" aria-label="Research interests">
                        <li>Artificial intelligence</li>
                        <li>Robotics</li>
                        <li>Reinforcement learning</li>
                        <li>Imitation learning</li>
                        <li>Computer Vision</li>
                        <li>World Models</li>
                        <li>Supervised Learning</li>
                    </ul>
                    <h2 class="hero-subtitle">Connect with me</h2>
                    <div class="social-inline">
                        {SOCIAL_LINKS.filter((link) => link.label !== 'Email').map((link) => (
                            <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
                        ))}
                    </div>
                    <div class="outreach-note">
                        <p>I share accessible robotics and AI content in Spanish through my channel <em>El Robot Barato</em>.</p>
                        <a href="https://www.instagram.com/robot_barato/" class="btn btn-outline" target="_blank" rel="noopener noreferrer">Visit El Robot Barato</a>
                    </div>
				</div>
				<div class="hero-image">
					<Image src={url('/jorge-ramirez.jpeg')} width={280} height={280} alt="Jorge Armando Ramirez Diaz" fetchpriority="high" decoding="async" />
                    <section class="academic-background" aria-labelledby="background-title">
                        <h2 id="background-title">Background</h2>
                        <div class="background-group">
                            <h3>Current Positions</h3>
                            <ul class="background-list">
                                <li>Postdoctoral Research Fellow, Facultad de Ingeniería, Universidad Autónoma de Querétaro (UAQ), Querétaro, Mexico, 2026–present.</li>
                                <li>Lecturer, Escuela Nacional de Estudios Superiores Unidad Juriquilla, Universidad Nacional Autónoma de México (UNAM), Querétaro, Mexico, 2026–present.</li>
                            </ul>
                        </div>
                        <div class="background-group">
                            <h3>Education</h3>
                            <ul class="background-list">
                                <li>Ph.D. in Automatic Control, Departamento de Control Automático, Centro de Investigación y de Estudios Avanzados del Instituto Politécnico Nacional (CINVESTAV-IPN), Mexico City, Mexico, 2019–2023.</li>
                                <li>M.Sc. in Automatic Control, Departamento de Control Automático, Centro de Investigación y de Estudios Avanzados del Instituto Politécnico Nacional (CINVESTAV-IPN), Mexico City, Mexico, 2017–2019.</li>
                                <li>B.Eng. in Mechatronics Engineering, Tecnológico Nacional de México / Instituto Tecnológico de Querétaro (TecNM/ITQ), Querétaro, Mexico, 2011–2016.</li>
                            </ul>
                        </div>
                    </section>
				</div>
			</section>

			<hr style="margin: 1.75rem 0 2.5rem; border-top: 1px solid var(--color-border);" />

			<div class="grid-2" style="gap: 4rem; margin-top: 0;">
                <section>
                    <h2 style="margin-top: 0;">Selected Publications</h2>
                    <div class="publication-list">
                        {publications.length > 0 ? publications.map((pub) => (
                            <div class="pub-mini-item">
                                <span class="pub-title">{pub.fields.title.replace(/[{}]/g, '')}</span>
                                <div class="pub-meta">
                                    {pub.authors.map(a => formatAuthor(a)).join(', ')}
                                    <br/>
                                    <span style="font-style: italic; color: var(--color-accent);">
                                        {(pub.fields.journal || pub.fields.booktitle || pub.fields.publisher || pub.fields.note || "Preprint").replace(/[{}]/g, '')}
                                    </span>
                                    {pub.fields.year && <span>, {pub.fields.year}</span>}
                                </div>
                            </div>
                        )) : <p>No publications found.</p>}
                    </div>
                    <div style="margin-top: 1.5rem;">
                        <a href={url('/publications')} style="font-weight: 600;">View Full List &rarr;</a>
                    </div>
                </section>

                <section>
                    <h2 style="margin-top: 0;">News</h2>
                    <ul class="news-list">
                        {posts.map(({ post, Content }) => (
                            <li class="news-item">
                                <span class="news-title">{post.data.title}</span>
                                <small class="news-date">
                                    {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
                                </small>
                                <div class="news-body">
                                    <Content />
                                </div>
                            </li>
                        ))}
                    </ul>
                    <a href={url('/archive')} style="font-weight: 600;">View News Archive &rarr;</a>
                </section>
            </div>

		</main>
		<Footer />
	</body>
</html>
