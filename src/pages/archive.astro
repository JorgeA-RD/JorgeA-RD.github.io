---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const postEntries = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const posts = await Promise.all(postEntries.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
}));

const groupedPosts = posts.reduce((acc, item) => {
    const date = new Date(item.post.data.pubDate);
    const year = date.getFullYear();
    const month = date.toLocaleString('default', { month: 'long' });

    if (!acc[year]) acc[year] = {};
    if (!acc[year][month]) acc[year][month] = [];

    acc[year][month].push(item);
    return acc;
}, {} as Record<number, Record<string, typeof posts>>);

const years = Object.keys(groupedPosts).map(Number).sort((a, b) => b - a);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`News Archive | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
        <style>
            .archive-year {
                margin-top: 3rem;
                margin-bottom: 1.5rem;
                font-size: 2rem;
                color: var(--color-text-main);
                border-bottom: 2px solid var(--color-border);
                padding-bottom: 0.5rem;
            }
            .archive-month {
                margin-top: 2rem;
                margin-bottom: 1rem;
                font-size: 1.5rem;
                color: var(--color-text-muted);
            }
            .archive-list {
                list-style: none;
                padding: 0;
                margin: 0;
            }
            .archive-item {
                margin-bottom: 2rem;
                padding-bottom: 2rem;
                border-bottom: 1px dashed var(--color-border);
            }
            .archive-item:last-child {
                border-bottom: none;
            }
            .archive-title {
                margin: 0 0 0.35rem;
                color: var(--color-text-main);
                font-family: var(--font-serif);
                font-size: 1.25rem;
                line-height: 1.3;
            }
            .archive-date {
                display: block;
                color: var(--color-text-muted);
                font-size: 0.85rem;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                margin-bottom: 0.85rem;
            }
            .archive-body {
                color: var(--color-text-muted);
                line-height: 1.7;
                max-width: 760px;
            }
            .archive-body :global(p) {
                margin: 0 0 1rem;
            }
            .archive-body :global(p:last-child) {
                margin-bottom: 0;
            }

            @media (max-width: 600px) {
                .archive-item {
                    margin-bottom: 1.5rem;
                    padding-bottom: 1.5rem;
                }
                .archive-title {
                    font-size: 1.15rem;
                }
                .archive-date {
                    font-size: 0.8rem;
                }
            }
        </style>
	</head>
	<body>
		<Header />
		<main>
			<h1>News Archive</h1>
            <p style="margin-bottom: 2rem; color: var(--color-text-muted); max-width: 720px;">
                A chronological record of academic updates and research milestones.
            </p>

            <div class="archive-container">
                {years.map((year) => (
                    <div class="year-section">
                        <h2 class="archive-year">{year}</h2>

                        {Object.entries(groupedPosts[year]).map(([month, monthPosts]) => (
                            <div class="month-section">
                                <h3 class="archive-month">{month}</h3>
                                <ul class="archive-list">
                                    {monthPosts.map(({ post, Content }) => (
                                        <li class="archive-item" id={post.id}>
                                            <h4 class="archive-title">{post.data.title}</h4>
                                            <span class="archive-date">
                                                <FormattedDate date={post.data.pubDate} />
                                            </span>
                                            <div class="archive-body">
                                                <Content />
                                            </div>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        ))}
                    </div>
                ))}

                {posts.length === 0 && (
                    <p style="text-align: center; color: var(--color-text-muted);">
                        No news found.
                    </p>
                )}
            </div>
		</main>
		<Footer />
	</body>
</html>
