---
const today = new Date();
import {
  CONTACT,
  FOOTER_CREDIT,
  SITE_DESCRIPTION,
  SITE_TITLE,
  SOCIAL_LINKS,
} from '../consts';
import Search from './Search.astro';
import { url } from '../utils/paths';
---

<footer class="site-footer">
    <div class="footer-content">
        <div class="footer-col brand-col">
            <h3>{SITE_TITLE}</h3>
            <p>
                {SITE_DESCRIPTION}
            </p>
            <div class="copyright">
                &copy; {today.getFullYear()} {SITE_TITLE}.<br/>All rights reserved.
            </div>
        </div>

        <div class="footer-col">
            <h4>Quick Links</h4>
            <ul>
                <li><a href={url('/')}>Home</a></li>
                <li><a href={url('/publications')}>Publications</a></li>
                <li><a href={url('/projects')}>Projects</a></li>
                <li><a href={url('/activities')}>Activities</a></li>
                <li><a href={url('/archive')}>News Archive</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Contact</h4>
            <address>
                {CONTACT.organization}<br/>
                {CONTACT.addressLines.map((line) => (
                    <>
                        {line}<br/>
                    </>
                ))}
            </address>
            <p style="margin-top: 1rem;">
                {CONTACT.emails.map((email) => (
                    <>
                        <a href={`mailto:${email}`} style="text-decoration: underline;">{email}</a><br/>
                    </>
                ))}
            </p>
        </div>

        <div class="footer-col">
            <h4>Connect</h4>
            <div class="social-links">
                {SOCIAL_LINKS.map((link) => (
                    <a
                        href={link.href}
                        target={link.href.startsWith('mailto:') ? undefined : '_blank'}
                        rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
                        aria-label={link.label}
                    >
                        {link.icon === 'scholar' && (
                            <svg fill="currentColor" viewBox="0 0 32 32" width="24" height="24" xmlns="http://www.w3.org/2000/svg"><path d="M14.573 2.729c-0.729 0.484-4.292 2.849-7.917 5.255s-6.589 4.396-6.589 4.422c0 0.026 0.182 0.146 0.406 0.266 0.224 0.13 3.797 2.109 7.953 4.411l7.542 4.193 0.193-0.099c0.109-0.052 2.891-1.641 6.188-3.521l5.99-3.427 0.036 10.599h3.557v-12.401l-4.615-3.094c-6.219-4.167-11.188-7.448-11.307-7.474-0.063-0.010-0.703 0.38-1.438 0.87zM7.141 22.177l0.016 2.672 8.828 5.292 8.891-5.339v-2.641c0-1.458-0.016-2.646-0.031-2.646-0.021 0-1.76 1.042-3.87 2.323l-4.406 2.661-0.578 0.339-1.755-1.052c-1.464-0.875-2.927-1.755-4.385-2.641l-2.672-1.615c-0.031-0.010-0.042 1.177-0.036 2.646z"></path></svg>
                        )}
                        {link.icon === 'email' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        )}
                        {link.icon === 'website' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                        )}
                        {link.icon === 'orcid' && (
                            <svg fill="currentColor" viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"></circle><path d="M7.7 7.4h1.7v9.2H7.7V7.4zm2.8 0h4.1c2.7 0 4.7 1.9 4.7 4.6s-2 4.6-4.7 4.6h-4.1V7.4zm1.7 1.5v6.2h2.3c1.8 0 3-1.2 3-3.1s-1.2-3.1-3-3.1h-2.3z" fill="var(--color-bg)"></path><circle cx="8.55" cy="5.8" r=".85" fill="var(--color-bg)"></circle></svg>
                        )}
                        {link.icon === 'wos' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><rect x="2.5" y="4" width="19" height="16" rx="3"></rect><path d="M6 8.5l1.4 7 2-5 2 5 1.4-7"></path><path d="M15.2 13.8c.5.5 1.2.8 2 .8 1 0 1.7-.5 1.7-1.2 0-.8-.8-1.1-1.8-1.4-1.1-.3-2.1-.7-2.1-1.9 0-1 .9-1.8 2.2-1.8.8 0 1.5.2 2 .7"></path></svg>
                        )}
                        {link.icon === 'researchgate' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="4"></rect><path d="M7 16V8h3.2c1.6 0 2.7 1 2.7 2.4 0 1.1-.7 2-1.8 2.3L13.5 16"></path><path d="M7 12.7h3.1"></path><path d="M17.7 10.4c-.5-.5-1.1-.8-1.9-.8-1.6 0-2.8 1.3-2.8 3.2s1.1 3.2 2.9 3.2c.8 0 1.5-.3 2-.8v-2.1h-2"></path></svg>
                        )}
                        {link.icon === 'github' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                        )}
                        {link.icon === 'linkedin' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                        )}
                        {link.icon === 'twitter' && (
                            <svg fill="currentColor" viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg"><path d="M18.9 2.5h3.1l-6.8 7.8L23.2 21.5h-6.3l-4.9-6.4-5.6 6.4H3.3l7.3-8.4L2.8 2.5h6.5l4.4 5.8 5.2-5.8zm-1.1 17h1.7L8.4 4.4H6.6l11.2 15.1z"></path></svg>
                        )}
                        {link.icon === 'instagram' && (
                            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                        )}
                    </a>
                ))}
            </div>
        </div>
    </div>
    <div class="footer-credit">
        Designed & Created by <a href={FOOTER_CREDIT.designerUrl} target="_blank" rel="noopener noreferrer">{FOOTER_CREDIT.designerName}</a> | <a href={FOOTER_CREDIT.sourceUrl} target="_blank" rel="noopener noreferrer">{FOOTER_CREDIT.sourceLabel}</a>
    </div>
</footer>

<Search />

<style>
	.site-footer {
		background-color: var(--color-bg-offset);
		color: var(--color-text-main);
		padding: 4rem 1rem;
        margin-top: auto;
        transition: background-color 0.3s ease;
        position: relative;
        padding-bottom: 0.5% !important;
	}

    .site-footer::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, var(--color-border) 20%, var(--color-border) 80%, transparent 100%);
        opacity: 0.6;
    }

    .footer-content {
        max-width: var(--max-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 3rem;
    }
    .footer-col h3 {
        font-family: var(--font-serif);
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: var(--color-accent);
    }
    .footer-col h4 {
        font-family: var(--font-sans);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1.25rem;
        color: var(--color-text-main);
    }
    .footer-col ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .footer-col ul li {
        margin-bottom: 0.75rem;
    }
    .footer-col a {
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }
    .footer-col a:hover {
        color: var(--color-accent);
    }
    .brand-col p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin-bottom: 1.5rem;
    }
    .copyright {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.5;
    }
    address {
        font-style: normal;
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--color-text-muted);
    }
    .social-links {
        display: flex;
        gap: 1rem;
    }
    .social-links a {
        color: var(--color-text-muted);
        transition: all 0.2s;
    }
    .social-links a:hover {
        color: var(--color-accent);
        transform: translateY(-2px);
    }

	@media (max-width: 900px) {
		.footer-content {
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }
        .brand-col {
            grid-column: span 2;
        }
	}
    @media (max-width: 600px) {
        .footer-content {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .brand-col {
            grid-column: span 1;
        }
        .social-links {
            justify-content: center;
        }
    }

    .footer-credit {
        text-align: center;
        margin-top: 0.25rem;
        padding-top: 0.5rem;
        border-top: 1px solid var(--color-border);
        font-size: 0.65rem;
        color: var(--color-text-main);
        line-height: 1.2;
    }
    .footer-credit a {
        color: var(--color-accent);
        text-decoration: none;
    }
    .footer-credit a:hover {
        color: var(--color-text-main);
        text-decoration: underline;
    }
</style>
